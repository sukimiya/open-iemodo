{
  "title": "Iemodo Lite - Overview",
  "uid": "iemodo-overview",
  "version": 1,
  "timezone": "browser",
  "panels": [
    {
      "title": "Request Rate",
      "type": "graph",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 8},
      "targets": [{"expr": "rate(http_server_requests_seconds_count[1m])", "legendFormat": "{{method}} {{uri}}"}]
    },
    {
      "title": "Error Rate",
      "type": "graph",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 8},
      "targets": [{"expr": "rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])", "legendFormat": "{{method}} {{uri}}"}]
    },
    {
      "title": "JVM Heap",
      "type": "graph",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 8},
      "targets": [{"expr": "jvm_memory_used_bytes{area=\"heap\"}", "legendFormat": "{{id}}"}]
    },
    {
      "title": "DB Connection Pool",
      "type": "graph",
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 8},
      "targets": [{"expr": "r2dbc_pool_active_connections", "legendFormat": "active"}]
    },
    {
      "title": "CPU Usage",
      "type": "graph",
      "gridPos": {"x": 8, "y": 8, "w": 8, "h": 8},
      "targets": [{"expr": "system_cpu_usage", "legendFormat": "system"}, {"expr": "process_cpu_usage", "legendFormat": "process"}]
    },
    {
      "title": "Response Time (p99)",
      "type": "graph",
      "gridPos": {"x": 16, "y": 8, "w": 8, "h": 8},
      "targets": [{"expr": "http_server_requests_seconds_max", "legendFormat": "{{method}} {{uri}}"}]
    }
  ],
  "schemaVersion": 14
}
